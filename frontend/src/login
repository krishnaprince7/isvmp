function DistrictMultiSelectWithCheckbox({
  districts,
  selectedDistricts,
  onChange,
  errors,
}) {
  const [isOpen, setIsOpen] = useState(false);
  const [searchTerm, setSearchTerm] = useState("");
  const dropdownRef = useRef(null);

  const handleToggle = (districtName) => {
    const newSelection = selectedDistricts.includes(districtName)
      ? selectedDistricts.filter((d) => d !== districtName)
      : [...selectedDistricts, districtName];

    onChange(newSelection);
  };

  const filteredDistricts = districts.filter((d) =>
    d.district_name.toLowerCase().includes(searchTerm.toLowerCase())
  );

  useEffect(() => {
    const handleClickOutside = (event) => {
      if (dropdownRef.current && !dropdownRef.current.contains(event.target)) {
        setIsOpen(false);
      }
    };
    document.addEventListener("mousedown", handleClickOutside);
    return () => document.removeEventListener("mousedown", handleClickOutside);
  }, [setIsOpen]);

  return (
    <div ref={dropdownRef}>
      <label className="text-sm font-semibold block mb-1">District *</label>

      {/* Dropdown */}
      <div className="relative">
        <div
          onClick={() => setIsOpen(!isOpen)}
          className="w-full p-2 border rounded cursor-pointer bg-white flex justify-between items-center"
        >
          <span className="text-gray-500">
            {selectedDistricts.length > 0
              ? `${selectedDistricts.length} District Selected`
              : "Select District"}
          </span>
          <span className="text-gray-400">▼</span>
        </div>

        {isOpen && (
          <div className="absolute z-10 w-full mt-1 bg-white border rounded shadow-lg max-h-60 overflow-auto">
            {/* Search */}
            <div className="p-2 border-b sticky top-0 bg-white">
              <input
                type="text"
                placeholder="Search districts..."
                value={searchTerm}
                onChange={(e) => setSearchTerm(e.target.value)}
                className="w-full p-2 border rounded text-sm"
                onClick={(e) => e.stopPropagation()}
              />
            </div>

            {/* ✅ Select All Checkbox - Top of List */}
            <div className="p-2 border-b bg-gray-50  top-[60px]">
              <label className="flex items-center gap-2 p-2 hover:bg-gray-100 cursor-pointer rounded font-semibold">
                <input
                  type="checkbox"
                  checked={
                    selectedDistricts.length === filteredDistricts.length &&
                    filteredDistricts.length > 0
                  }
                  onChange={(e) => {
                    if (e.target.checked) {
                      // Select all filtered districts
                      const allFiltered = filteredDistricts.map(
                        (d) => d.district_name
                      );
                      onChange([
                        ...new Set([...selectedDistricts, ...allFiltered]),
                      ]);
                    } else {
                      // Deselect all filtered districts
                      const filteredNames = filteredDistricts.map(
                        (d) => d.district_name
                      );
                      onChange(
                        selectedDistricts.filter(
                          (name) => !filteredNames.includes(name)
                        )
                      );
                    }
                  }}
                  className="w-4 h-4 cursor-pointer"
                />
                <span className="text-sm text-blue-700">
                  Select All {searchTerm && `(${filteredDistricts.length} filtered)`}
                </span>
              </label>
            </div>

            {/* List */}
            <div className="p-2">
              {filteredDistricts.length === 0 ? (
                <div className="text-center text-gray-500 py-2">
                  No districts found
                </div>
              ) : (
                filteredDistricts.map((d) => (
                  <label
                    key={d.id}
                    className="flex items-center gap-2 p-2 hover:bg-gray-100 cursor-pointer rounded"
                  >
                    <input
                      type="checkbox"
                      checked={selectedDistricts.includes(d.district_name)}
                      onChange={() => handleToggle(d.district_name)}
                      className="w-4 h-4 cursor-pointer"
                    />
                    <span className="text-sm">{d.district_name}</span>
                  </label>
                ))
              )}
            </div>

            {/* Buttons */}
            <div className="p-2 border-t bg-gray-50 flex gap-2"></div>
          </div>
        )}
      </div>

      {/* Error (API uses district_ids) */}
      {errors?.district_ids && (
        <p className="text-red-500 text-sm mt-1">{errors.district_ids[0]}</p>
      )}
    </div>
  );
}

// ✅ NEW: Multi-Select Ghat Component
function GhatMultiSelectWithCheckbox({
  ghats,
  selectedGhats,
  onChange,
  errors,
  disabled,
}) {
  const [isOpen, setIsOpen] = useState(false);
  const [searchTerm, setSearchTerm] = useState("");
  const dropdownRef = useRef(null);

  const handleToggle = (ghatId) => {
    const newSelection = selectedGhats.includes(ghatId)
      ? selectedGhats.filter((g) => g !== ghatId)
      : [...selectedGhats, ghatId];

    onChange(newSelection);
  };

  const filteredGhats = ghats.filter((g) =>
    g.ghaat_name.toLowerCase().includes(searchTerm.toLowerCase())
  );

  useEffect(() => {
    const handleClickOutside = (event) => {
      if (dropdownRef.current && !dropdownRef.current.contains(event.target)) {
        setIsOpen(false);
      }
    };
    document.addEventListener("mousedown", handleClickOutside);
    return () => document.removeEventListener("mousedown", handleClickOutside);
  }, [setIsOpen]);

  return (
    <div>
      <label className="text-sm font-semibold block mb-1">Ghaat *</label>

      <div ref={dropdownRef} className="relative">
        <div
          onClick={() => !disabled && setIsOpen(!isOpen)}
          className={`w-full p-2 border rounded cursor-pointer bg-white flex justify-between items-center ${
            disabled ? "opacity-50 cursor-not-allowed" : ""
          }`}
        >
          <span className="text-gray-500">
            {selectedGhats.length > 0
              ? `${selectedGhats.length} Ghat Selected`
              : disabled
              ? "Select Districts First"
              : "Select Ghaats"}
          </span>
          <span className="text-gray-400">▼</span>
        </div>

        {isOpen && !disabled && (
          <div className="absolute z-10 w-full mt-1 bg-white border rounded shadow-lg max-h-60 overflow-auto">
            {/* Search */}
            <div className="p-2 border-b sticky top-0 bg-white">
              <input
                type="text"
                placeholder="Search Ghaats..."
                value={searchTerm}
                onChange={(e) => setSearchTerm(e.target.value)}
                className="w-full p-2 border rounded text-sm"
                onClick={(e) => e.stopPropagation()}
              />
            </div>

            {/* Select All Checkbox */}
            <div className="p-2 border-b bg-gray-50">
              <label className="flex items-center gap-2 p-2 hover:bg-gray-100 cursor-pointer rounded font-semibold">
                <input
                  type="checkbox"
                  checked={
                    selectedGhats.length === filteredGhats.length &&
                    filteredGhats.length > 0
                  }
                  onChange={(e) => {
                    if (e.target.checked) {
                      const allFiltered = filteredGhats.map((g) => g.id);
                      onChange([...new Set([...selectedGhats, ...allFiltered])]);
                    } else {
                      const filteredIds = filteredGhats.map((g) => g.id);
                      onChange(selectedGhats.filter((id) => !filteredIds.includes(id)));
                    }
                  }}
                  className="w-4 h-4 cursor-pointer"
                />
                <span className="text-sm text-blue-700">
                  Select All {searchTerm && `(${filteredGhats.length} filtered)`}
                </span>
              </label>
            </div>

            {/* List */}
            <div className="p-2">
              {filteredGhats.length === 0 ? (
                <div className="text-center text-gray-500 py-2">No ghats found</div>
              ) : (
                filteredGhats.map((g) => (
                  <label
                    key={g.id}
                    className="flex items-center gap-2 p-2 hover:bg-gray-100 cursor-pointer rounded"
                  >
                    <input
                      type="checkbox"
                      checked={selectedGhats.includes(g.id)}
                      onChange={() => handleToggle(g.id)}
                      className="w-4 h-4 cursor-pointer"
                    />
                    <span className="text-sm">{g.ghaat_name}</span>
                  </label>
                ))
              )}
            </div>
          </div>
        )}
      </div>

      {/* Error (API uses ghat_ids) */}
      {errors?.ghat_ids && (
        <p className="text-red-500 text-sm mt-1">{errors.ghat_ids[0]}</p>
      )}
    </div>
  );
}

export default function Usermanagment() {
  const location = useLocation();

  useEffect(() => {
    if (location.state?.tab === "manage") {
      setView("manage");
    }
  }, [location]);

  const navigate = useNavigate();

  const [loading, setLoading] = useState(false);
  const [view, setView] = useState("create"); // default tab
  const [errors, setErrors] = useState({}); // used for create user API errors
  const [tehsils, setTehsils] = useState([]);

  /* ---------- role state ---------- */
  const [form, setForm] = useState({ roleName: "" });
  const [roles, setRoles] = useState([]);
  const [showPerms, setShowPerms] = useState(true); // 👁 toggle for perms

  const [districts, setDistricts] = useState([]);
  const [designation, setDesignation] = useState([]);

  const [editModal, setEditModal] = useState(false);
  const [editData, setEditData] = useState({ id: null, name: "" });

  const [deleteModal, setDeleteModal] = useState(false);
  const [roleToDelete, setRoleToDelete] = useState(null);

  const [selectedDistrict, setSelectedDistrict] = useState(null);
  const [loadingTehsils, setLoadingTehsils] = useState(false);

  const [vendorDistricts, setVendorDistricts] = useState([]);

  const [ghats, setGhats] = useState([]);
  const [loadingGhats, setLoadingGhats] = useState(false);

  /* ---------- user state (Create User form) ---------- */
  const [userForm, setUserForm] = useState({
    fullName: "",
    email: "",
    password: "",
    confirmPassword: "",
    role: "",
    district: "", // for create user it's single district name
    designation: "",
    contact: "",
    tehsil: "",
    district_code: "",
    ghats: [], // not used for create user
  });
  const [users, setUsers] = useState([]);
  const [showPass, setShowPass] = useState(false);
  const [showConfirm, setShowConfirm] = useState(false);

  const [authUser, setAuthUser] = useState(null);

  /* ---------- vendor state (separate) ---------- */
  const [vendorForm, setVendorForm] = useState({
    fullName: "",
    email: "",
    password: "",
    confirmPassword: "",
    district: [], // array of district names for vendor
    contact: "",
    ghats: [], // array of ghat IDs
  });
  const [vendorErrors, setVendorErrors] = useState({});
  const [vendorLoading, setVendorLoading] = useState(false);

  useEffect(() => {
    const user = JSON.parse(localStorage.getItem("user"));
    setAuthUser(user);

    // If role_id is 1 (district_nodal), auto-set district for create-user form (not vendor)
    if (user?.role_id === 1 && user?.district_id) {
      setUserForm((prev) => ({
        ...prev,
        district_code: user.district_id,
      }));

      fetchTehsils(user.district_id); // 👈 fetch tehsils directly for create user
    }
  }, []);

  useEffect(() => {
    const fetchVendorDistricts = async () => {
      try {
        const { data } = await api.get("/district-list");
        if (data?.data) setVendorDistricts(data.data);
      } catch (err) {
        console.error("Failed to fetch vendor districts:", err);
      }
    };

    fetchVendorDistricts();
  }, []);

  useEffect(() => {
    const fetchDistricts = async () => {
      try {
        const isAdmin = authUser?.role_id === null;

        const { data } = await api.get("/district-list", {
          params: isAdmin ? { excludeAssigned: true } : {},
        });

        if (data?.data) setDistricts(data.data);
      } catch (err) {
        console.error("Failed to fetch districts:", err);
      }
    };

    if (authUser) fetchDistricts();
  }, [authUser]);

  useEffect(() => {
    const fetchDesignation = async () => {
      try {
        const { data } = await api.get("/designation");
        if (data?.data) setDesignation(data.data);
      } catch (err) {
        console.error("Failed to fetch designation:", err);
      }
    };

    fetchDesignation();
  }, []);

  useEffect(() => {
    const fetchRoles = async () => {
      try {
        const { data } = await api.get("/roles");
        if (data?.data) setRoles(data.data);
      } catch (err) {
        console.error("Failed to load roles:", err);
      }
    };

    fetchRoles();
  }, []);

  // Fetch Ghats for vendor when vendor view active and vendorForm.district changes
  useEffect(() => {
    const fetchGhats = async () => {
      if (view === "vendor" && vendorForm.district.length > 0) {
        setLoadingGhats(true);
        try {
          // Get district IDs from selected district names
          const districtIds = vendorForm.district
            .map((distName) => {
              return vendorDistricts.find((d) => d.district_name === distName)
                ?.id;
            })
            .filter(Boolean);

          const { data } = await api.post("/user-district-ghat", {
            district_id: districtIds,
          });

          if (data?.data) {
            setGhats(data.data);
          } else {
            setGhats([]);
          }
        } catch (err) {
          console.error("Failed to fetch ghats:", err);
        } finally {
          setLoadingGhats(false);
        }
      } else {
        setGhats([]);
        setVendorForm((prev) => ({ ...prev, ghats: [] }));
      }
    };

    fetchGhats();
  }, [vendorForm.district, view, vendorDistricts]);

  /* ---------- handlers for vendor form (separate) ---------- */
  const handleVendorFieldChange = (e) => {
    const { name, value } = e.target;
    setVendorForm((prev) => ({ ...prev, [name]: value }));

    // Clear vendor error for that field
    setVendorErrors((prev) => {
      if (!prev) return {};
      const copy = { ...prev };
      if (name === "fullName") delete copy.name;
      else if (name === "confirmPassword") delete copy.password_confirmation;
      else delete copy[name];
      return copy;
    });
  };

  const handleVendorDistrictChange = (selected) => {
    setVendorForm((prev) => ({ ...prev, district: selected }));
    // Clear district_ids vendor error
    setVendorErrors((prev) => {
      if (!prev) return {};
      const copy = { ...prev };
      delete copy.district_ids;
      return copy;
    });
  };

  const handleVendorGhatChange = (selected) => {
    setVendorForm((prev) => ({ ...prev, ghats: selected }));
    // Clear ghat_ids vendor error
    setVendorErrors((prev) => {
      if (!prev) return {};
      const copy = { ...prev };
      delete copy.ghat_ids;
      return copy;
    });
  };

  /* ---------- role helpers ---------- */
  const onRoleChange = (e) => setForm({ roleName: e.target.value });

  useEffect(() => {
    const user = JSON.parse(localStorage.getItem("user")); // assume login pe yeh save hota h
    setAuthUser(user);
  }, []);

  const addRole = async () => {
    const name = form.roleName.trim();
    if (!name) return alert("Enter role name");

    try {
      const { data } = await api.post("/roles", { name });

      // Add newly created role to list
      setRoles([...roles, data.data]);
      setForm({ roleName: "" });
      toast.success("Role added successfully!");
    } catch (err) {
      if (err.response?.data?.errors?.name) {
        toast.error(err.response.data.errors.name[0]);
      } else {
        toast.error("Failed to add role");
      }
    }
  };

  const openEditModal = (role) => {
    setEditData({ id: role.id, name: role.name });
    setEditModal(true);
  };

  const updateRole = async () => {
    try {
      const { data } = await api.put(`/roles/${editData.id}`, {
        name: editData.name,
      });
      const updatedRoles = roles.map((r) =>
        r.id === editData.id ? data.role : r
      );
      setRoles(updatedRoles);
      setEditModal(false);
      toast.success("Role updated successfully!");
    } catch (err) {
      toast.error("Failed to update role");
    }
  };

  const confirmDeleteRole = async () => {
    try {
      await api.delete(`/roles/${roleToDelete.id}`);
      setRoles(roles.filter((r) => r.id !== roleToDelete.id));
      toast.success("Role deleted successfully!");
    } catch (err) {
      toast.error("Failed to delete role");
    } finally {
      setDeleteModal(false);
      setRoleToDelete(null);
    }
  };

  /* ---------- user helpers (create user) ---------- */
  // Map local form field name to API error key for create user
  const mapFieldToErrorKey = (name) => {
    if (name === "fullName") return "name";
    if (name === "confirmPassword") return "password_confirmation";
    if (name === "contact") return "number";
    return name;
  };

  // Generic field change handler that also clears API validation error for create user
  const onUserChange = (e) => {
    const { name, value } = e.target;

    // handle district selection by name in non-vendor create tab
    if (name === "district" && value) {
      const selected = districts.find((d) => d.district_name === value);

      if (selected) {
        setSelectedDistrict(selected);
        setLoadingTehsils(true); // Show loading state for tehsils

        setUserForm((prevState) => ({
          ...prevState,
          district_code: selected.id,
          district: value,
          tehsil: "", // Reset tehsil when district changes
        }));

        // Fetch tehsils for the selected district
        fetchTehsils(selected.id);

        // clear district related API error for create user
        setErrors((prev) => {
          if (!prev) return {};
          const copy = { ...prev };
          delete copy.district_id;
          delete copy.district_ids;
          return copy;
        });
      }
      return;
    }

    // update value
    setUserForm((prevState) => ({
      ...prevState,
      [name]: value,
    }));

    // clear corresponding API error
    const apiKey = mapFieldToErrorKey(name);
    setErrors((prev) => {
      if (!prev) return {};
      const copy = { ...prev };
      delete copy[apiKey];
      return copy;
    });
  };

  const fetchTehsils = async (districtCode) => {
    try {
      const res = await api.get(`/get-tehsils`, {
        params: { district_code: Number(districtCode) },
      });
      setTehsils(Array.isArray(res.data.data) ? res.data.data : []);
    } catch (error) {
      console.error("Failed to fetch tehsils:", error);
      setTehsils([]);
      toast.error("Could not load tehsils.");
    } finally {
      setLoadingTehsils(false);
    }
  };

  const addUser = () => {
    const vals = Object.values(userForm).map((v) =>
      typeof v === "string" ? v.trim() : v
    );
    if (
      vals.some(
        (v) => v === "" || v === null || (Array.isArray(v) && v.length === 0)
      )
    )
      return alert("Fill all fields");
    if (userForm.password !== userForm.confirmPassword)
      return alert("Passwords do not match");
    if (!userForm.district_code) return alert("Please select a district");

    // Add user with the district_code instead of district_name
    setUsers([...users, userForm]);
    setUserForm({
      fullName: "",
      email: "",
      district: "", // Reset to empty
      district_code: "", // Reset district_code
      tehsil: "", // Reset tehsil
      designation: "",
      role: "",
      password: "",
      confirmPassword: "",
    });
    setView("manage");
  };

  const [userLoading, setUserLoading] = useState(false);
  const [userList, setUserList] = useState([]);

  useEffect(() => {
    if (view === "manage") {
      setUserLoading(true);
      api
        .get("/user-list")
        .then((res) => {
          setUserList(res.data?.data || []);
        })
        .catch((err) => {
          console.error("Failed to fetch users", err);
        })
        .finally(() => {
          setUserLoading(false);
        });
    }
  }, [view]);

  // Pagination
  const [currentPage, setCurrentPage] = useState(1);
  const itemsPerPage = 10;

  const indexOfLastItem = currentPage * itemsPerPage;
  const indexOfFirstItem = indexOfLastItem - itemsPerPage;
  const currentUsers = userList.slice(indexOfFirstItem, indexOfLastItem);
  const totalPages = Math.ceil(userList.length / itemsPerPage);

  // for popup
  const [showPopup, setShowPopup] = useState(false);
  const [selectedUserId, setSelectedUserId] = useState(null);

  const closePopup = () => {
    setSelectedUserId(null);
    setShowPopup(false);
  };

  const handleConfirmDelete = async () => {
    try {
      const res = await api.delete(`/user-delete/${selectedUserId}`);
      console.log("User deleted:", res.data);

      setUserList((prevList) =>
        prevList.filter((user) => user.id !== selectedUserId)
      );

      if (user?.role_id === 1) {
        toast.success("Ghat Incharge deleted successfully!");
      } else {
        toast.success("User deleted successfully!");
      }

      setShowPopup(false); // Close the popup
    } catch (error) {
      console.error("Error deleting user:", error);
      toast.error("Failed to delete user!");
    }
  };

  const getPaginationButtons = () => {
    const buttons = [];
    const maxVisibleButtons = 5;

    if (totalPages <= maxVisibleButtons) {
      for (let i = 1; i <= totalPages; i++) {
        buttons.push(i);
      }
    } else {
      // Always show first page
      buttons.push(1);

      // Calculate range around current page
      let startPage = Math.max(2, currentPage - 1);
      let endPage = Math.min(totalPages - 1, currentPage + 1);

      // Add ellipsis if needed after first page
      if (startPage > 2) {
        buttons.push("...");
      } else {
        startPage = 2;
      }

      // Add page numbers around current page
      for (let i = startPage; i <= endPage; i++) {
        buttons.push(i);
      }

      // Add ellipsis if needed before last page
      if (endPage < totalPages - 1) {
        buttons.push("...");
      }

      // Always show last page
      buttons.push(totalPages);
    }

    return buttons;
  };

  /* ====================================== JSX ====================================== */
  return (
    <div className="p-4 min-h-screen max-w-5xl mx-auto">
      <h1 className="text-xl font-semibold text-center mb-6">
        User Management
      </h1>
      <Toaster position="top-right" reverseOrder={false} />

      {/* ---------- top nav ---------- */}
      <div className="grid sm:grid-cols-3 md:grid-cols-3 items-center text-center gap-4 mb-8">
        <button
          onClick={() => {
            // Reset create-user errors when switching to create
            setErrors({});
            setView("create");
          }}
          className={pill(view === "create")}
        >
          <IconWrap>
            <FaUserPlus />
          </IconWrap>
          {authUser?.role_id === 1 ? "Create Ghat Incharge" : "Create User"}
        </button>

        <button
          onClick={() => {
